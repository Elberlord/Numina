rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.uid == "6zJhAeRF9JRAilw6yvQQvLiN8bc2";
    }

    function hasActiveDevice() {
      return signedIn()
        && exists(/databases/$(database)/documents/devices/$(request.auth.uid))
        && get(/databases/$(database)/documents/devices/$(request.auth.uid)).data.active == true;
    }

    function canOperate() {
      return isAdmin() || hasActiveDevice();
    }

    match /deviceRequests/{uid} {
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "pending"
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasOnly([
          "uid",
          "userName",
          "deviceName",
          "appVersion",
          "status",
          "createdAt"
        ]);

      allow get: if signedIn()
        && (isAdmin() || request.auth.uid == uid);

      allow list, update, delete: if isAdmin();
    }

    match /devices/{uid} {
      allow get: if signedIn()
        && (isAdmin() || request.auth.uid == uid);

      allow list, create, delete: if isAdmin();

      allow update: if isAdmin() || (
        signedIn()
        && request.auth.uid == uid
        && resource.data.active == true
        && request.resource.data.active == resource.data.active
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "lastSeenAt",
          "appVersion"
        ])
      );
    }

    match /campaigns/{id} {
      allow read: if canOperate();
      allow create: if canOperate()
        && request.resource.data.id == id
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.updatedByUid == request.auth.uid;
      allow update: if canOperate()
        && request.resource.data.id == resource.data.id
        && request.resource.data.updatedByUid == request.auth.uid;
      allow delete: if false;
    }

    match /sales/{id} {
      allow read: if canOperate();
      allow create: if canOperate()
        && request.resource.data.id == id
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.updatedByUid == request.auth.uid;
      allow update: if canOperate()
        && request.resource.data.id == resource.data.id
        && request.resource.data.updatedByUid == request.auth.uid;
      allow delete: if false;
    }

    match /results/{id} {
      allow read: if canOperate();
      allow create: if canOperate()
        && request.resource.data.id == id
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.updatedByUid == request.auth.uid;
      allow update: if canOperate()
        && request.resource.data.id == resource.data.id
        && request.resource.data.updatedByUid == request.auth.uid;
      allow delete: if false;
    }

    match /deliveries/{id} {
      allow read: if canOperate();
      allow create: if canOperate()
        && request.resource.data.id == id
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.updatedByUid == request.auth.uid;
      allow update: if canOperate()
        && request.resource.data.id == resource.data.id
        && request.resource.data.updatedByUid == request.auth.uid;
      allow delete: if false;
    }

    match /audit/{auditId} {
      allow create: if canOperate()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.createdAt == request.time;
      allow read, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
