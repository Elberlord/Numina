{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "allowImportingTsExtensions": true
  },
  "include": ["src/app-src.js", "src/modules/**/*.js", "src/types/**/*.d.ts"]
}
